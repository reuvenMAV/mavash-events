# Google Apps Script Web App URL (Deploy → Execute as: Me → Anyone)
GAS_WEB_APP_URL=

# Must match Script Property ADMIN_ACCESS_KEY in Apps Script (super-admin only)
ADMIN_ACCESS_KEY=

# Session signing (openssl rand -hex 32)
AUTH_SECRET=

# Shared with GAS Script Property INTERNAL_API_SECRET
INTERNAL_API_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {SITE}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Canonical site URL (OAuth redirects)
NEXT_PUBLIC_SITE_URL=https://mavash-events.vercel.app

# Optional — enables "דוגמה" button on homepage (server-side preferred)
# DEMO_EVENT_TOKEN=
# NEXT_PUBLIC_DEMO_EVENT_TOKEN=
