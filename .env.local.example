# Google Apps Script Web App URL (Deploy → Execute as: Me → Anyone)
GAS_WEB_APP_URL=

# Must match Script Property ADMIN_ACCESS_KEY in Apps Script (super-admin only)
ADMIN_ACCESS_KEY=

# Session signing (openssl rand -hex 32)
AUTH_SECRET=

# Shared with GAS Script Property INTERNAL_API_SECRET
INTERNAL_API_SECRET=

# Optional — enables "דוגמה" button on homepage
# NEXT_PUBLIC_DEMO_EVENT_TOKEN=
