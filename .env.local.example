# Google Apps Script Web App URL (Deploy → Execute as: Me → Anyone)
GAS_WEB_APP_URL=

# Must match Script Property ADMIN_ACCESS_KEY in Apps Script (legacy admin — optional)
ADMIN_ACCESS_KEY=

# Session signing (openssl rand -hex 32)
AUTH_SECRET=

# Shared with GAS Script Property INTERNAL_API_SECRET — tenant-scoped owner API
INTERNAL_API_SECRET=

# Backend: gas (default) | sheets-hybrid (future — see docs/INTEGRATIONS.md)
# EVENTS_BACKEND=gas

# --- Chat + WhatsApp (n8n) ---
# Full URL from: ./scripts/n8n-deploy-events-chat.sh
N8N_CHAT_WEBHOOK_URL=
# N8N_CHAT_WEBHOOK_KEY=
# WhatsApp wa.me number (no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=972544223911

# --- HERMES / n8n (optional — connects to existing automations) ---
# Production webhook URL from n8n workflow "MAVASH Events — HERMES webhook"
N8N_EVENTS_WEBHOOK_URL=
# Shared secret — must match n8n env N8N_EVENTS_WEBHOOK_KEY
N8N_EVENTS_WEBHOOK_KEY=

# --- Google Sheets direct (optional hybrid — see raouben-site pattern) ---
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# SPREADSHEET_ID=

# Optional — enables "דוגמה" button on homepage without pasting token manually
# NEXT_PUBLIC_DEMO_EVENT_TOKEN=
# N8N_BASE_URL=
# N8N_API_KEY=
