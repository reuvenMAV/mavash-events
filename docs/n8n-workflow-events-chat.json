      "parameters": {
        "jsCode": "let parsed = $json.output;\n\nif (typeof parsed === 'string') {\n  try { parsed = JSON.parse(parsed); } catch (e) {\n    const errReply = 'מצטער, הייתה תקלה. נסה שוב?';\n    return [{ json: { ok: false, reply: errReply, output: errReply, text: errReply, _clean_output: errReply, last_message: '', done: false } }];\n  }\n}\n\nif (!parsed || typeof parsed !== 'object') {\n  const errReply = 'מצטער, הייתה תקלה. נסה שוב?';\n  return [{ json: { ok: false, reply: errReply, output: errReply, text: errReply, _clean_output: errReply, last_message: '', done: false } }];\n}\n\nconst lead = parsed.lead || {};\nconst ctx = $('2️⃣ Set Session Context').item.json;\nconst replyText = parsed.reply || '';\nconst summaryText = (lead.summary || '').trim();\nconst leadSource = ctx.LEAD_SOURCE || 'אתר — ראובן מבשב';\n\nreturn [{ json: {\n  ok: true,\n  reply: replyText,\n  output: replyText,\n  text: replyText,\n  _clean_output: replyText,\n  last_message: summaryText,\n  done: !!parsed.done,\n  name: (lead.name || '').trim(),\n  phone: String(lead.phone || '').replace(/\\D/g, ''),\n  email: (lead.email || '').trim(),\n  summary: summaryText,\n  chat_id: ctx.sessionId,\n  service: ctx.SERVICE_KEY,\n  status: 'חדש',\n  source: leadSource,\n  lead_source: leadSource,\n  airtable_source: 'אתר',\n  page_url: ctx.PAGE_URL || ctx.SITE_URL || '',\n  created_at: new Date().toISOString(),\n  updated_at: new Date().toISOString()\n} }];"
      },
