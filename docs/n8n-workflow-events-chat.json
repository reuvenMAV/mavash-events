        "jsCode": "const raw = $input.first().json;\nconst body = raw.body || raw;\nlet text = '';\nlet chatId = '';\nif (body.typeWebhook === 'incomingMessageReceived') {\n  text = body.messageData?.textMessageData?.textMessage\n    || body.messageData?.extendedTextMessageData?.text || '';\n  chatId = body.senderData?.chatId || '';\n  if (!text || String(chatId).includes('@g.us')) return [];\n  return [{ json: {\n    chatInput: String(text).trim(),\n    sessionId: 'wa-' + chatId,\n    channel: 'whatsapp',\n    waChatId: chatId,\n    metadata: { source: 'WhatsApp', sourceType: 'whatsapp_inbound', sessionId: 'wa-' + chatId }\n  }}];\n}\nreturn [];"
